SUPABASE_URL=###
SUPABASE_KEY=###

# --- E2E (Playwright) ---
# All five vars below MUST be set before `npm run test:e2e`. The primary
# account is reused across runs (signed in once by tests/e2e/auth.setup.ts
# and persisted to playwright/.auth/user.json); ephemeral users for risk
# specs are created/torn-down via the admin client.

# Long-lived dedicated test account (NOT a personal Supabase user).
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# Supabase URL + anon key. Locally these come from `supabase status`;
# in CI they are sourced from GitHub Actions secrets. SUPABASE_URL and
# SUPABASE_KEY are listed at the top of this file and reused by E2E.

# Service-role key for admin-only operations (creating/deleting ephemeral
# users, seeding reference data). NEVER commit this value.
SUPABASE_SERVICE_ROLE_KEY=
